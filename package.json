{
  "name": "vizzo1",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @vizzo/landing dev",
    "dev:landing": "bun run --filter @vizzo/landing dev",
    "dev:dashboard": "bun run --filter @vizzo/dashboard dev",
    "dev:storefront": "bun run --filter @vizzo/storefront dev",
    "build": "bun run --filter @vizzo/shared build && bun run --filter @vizzo/landing build",
    "build:landing": "bun run --filter @vizzo/landing build",
    "build:dashboard": "bun run --filter @vizzo/dashboard build",
    "build:storefront": "bun run --filter @vizzo/storefront build",
    "lint": "bun run --filter '*' lint"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "wrangler": "^4.14.4"
  }
}
